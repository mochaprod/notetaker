generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String       @id
  name          String
  email         String       @unique
  emailVerified Boolean      @default(false)
  image         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  accounts      Account[]
  admin         AdminUser?
  summaries     Digest[]
  invites       InviteCode[]
  notes         Note[]
  notepads      Notepad[]
  sessions      Session[]
  aiCredit      AICredit?

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@index([userId, providerId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model AdminUser {
  userId String @id
  user   User   @relation(fields: [userId], references: [id])

  @@map("admin_user")
}

model InviteCode {
  id        String    @id @default(uuid())
  code      String    @unique
  maxUses   Int       @default(1)
  uses      Int       @default(0)
  expiresAt DateTime?
  inviterId String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  inviter   User?     @relation(fields: [inviterId], references: [id])

  @@index([inviterId])
  @@map("invite_code")
}

model Note {
  message           String
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @default(now())
  userId            String
  id                String             @id @default(uuid()) @db.Uuid
  digestCorrections DigestCorrection[]
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  digestItems       DigestItem[]       @relation("DigestItemToNote")
  digestThemes  DigestTheme[]  @relation("DigestThemeToNote")

  @@index([createdAt, id])
  @@map("note")
}

model Notepad {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String
  dateKey   String
  title     String   @default("Untitled")
  content   Json     @db.JsonB
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@unique([userId, dateKey])
  @@map("notepad")
}

model Digest {
  userId            String
  startDate         String
  endDate           String
  summary           String
  id                String                   @id @default(uuid()) @db.Uuid
  user              User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  corrections       DigestCorrection[]
  followUpQuestions DigestFollowUpQuestion[]
  items             DigestItem[]
  dirty             Boolean @default(false)
  themes    DigestTheme[]

  @@index([userId])
  @@index([userId, startDate, endDate])
  @@map("digest")
}

model DigestItem {
  content   String
  category  String?
  datetime  DateTime?
  important Boolean   @default(false)
  id        String    @id @default(uuid()) @db.Uuid
  digestId  String    @db.Uuid
  digest    Digest    @relation(fields: [digestId], references: [id], onDelete: Cascade)
  notes     Note[]    @relation("DigestItemToNote")

  @@index([digestId])
  @@map("digest_item")
}

model DigestTheme {
  id          String @id @default(uuid()) @db.Uuid
  digestItemId    String @db.Uuid
  name        String
  description String
  digest Digest @relation(fields: [digestItemId], references: [id], onDelete: Cascade)
  notes       Note[] @relation("DigestThemeToNote")

  @@index([digestItemId])
  @@map("digest_theme")
}

model DigestCorrection {
  id          String  @id @default(uuid()) @db.Uuid
  noteId      String  @db.Uuid
  explanation String
  confidence  Decimal
  digestId    String  @db.Uuid
  digest      Digest  @relation(fields: [digestId], references: [id], onDelete: Cascade)
  note        Note    @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@map("digest_correction")
}

model DigestFollowUpQuestion {
  id       String  @id @default(uuid()) @db.Uuid
  digestId String  @db.Uuid
  question String
  answer   String?
  digest   Digest  @relation(fields: [digestId], references: [id], onDelete: Cascade)

  @@map("digest_follow_up_question")
}

model Todo {
  id String @id @default(uuid()) @db.Uuid
  userId String
  content String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  done Boolean
  dateTime DateTime?
  important Boolean @default(false)

  @@map("todo")
}

model AICredit {
  userId String @id
  credits Int
  updatedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ai_credit")
}
